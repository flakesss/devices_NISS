# Salin file ini ke .env dan isi dengan nilai yang sesuai
# cp .env.example .env

# ── MQTT Broker (HiveMQ Cloud) ──────────────────────────────────────────────
MQTT_HOST=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=your_username
MQTT_PASSWORD=your_password
DEVICE_ID=endoskop-01

# ── Kamera ───────────────────────────────────────────────────────────────────
CAMERA_INDEX=0
FRAME_WIDTH=1280
FRAME_HEIGHT=720
VIDEO_FPS=20
JPEG_QUALITY=80
MEDIA_DIR=/path/to/media

# ── Flask Stream ─────────────────────────────────────────────────────────────
STREAM_PORT=5000

# ── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_service_role_key
SUPABASE_BUCKET=endoskop-media
