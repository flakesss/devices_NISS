# ====== KONFIGURASI CLOUDFLARE TUNNEL (Docker Compose) ======
CLOUDFLARE_TOKEN=your_cloudflare_tunnel_token_here

# ====== KONFIGURASI BROKER MQTT ======
# Jika Pi & broker satu LAN: localhost atau IP PC Lab
# Jika beda jaringan lewat tunnel: localhost (karena di-proxy oleh cloudflared access tcp ke port 1883)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
DEVICE_ID=endoskop-01

# ====== KONFIGURASI KAMERA & STREAM ======
CAMERA_INDEX=0
FRAME_WIDTH=1280
FRAME_HEIGHT=720
VIDEO_FPS=20
JPEG_QUALITY=80
MEDIA_DIR=/path/to/media
STREAM_PORT=5000

# ====== KONFIGURASI COMPRESSIVE SENSING (CS) ======
CS_BLOCK_SIZE=64
CS_MR_PERCENT=100

# ====== KONFIGURASI SUPABASE STORAGE & DB ======
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your_service_role_key
SUPABASE_BUCKET=endoskop-media

# ====== KONFIGURASI MICROSERVICE PHARYNGITIS (Opsional) ======
MODEL_PATH=model_scripted.pt
IMG_SIZE=224
API_TOKEN=

# ====== KONFIGURASI ENKRIPSI AES-128-GCM ======
# Key AES-128 dalam hex (32 karakter hex = 16 byte).
# Jika dikosongkan, key otomatis dibaca dari file aes_key.bin.
# Jika aes_key.bin juga belum ada, key baru di-generate otomatis saat pertama kali
# mqtt_server.py dijalankan, lalu disimpan ke aes_key.bin.
# PENTING: Key HARUS identik dengan backend! Salin hex key ke .env backend.
NISS_AES_KEY=
